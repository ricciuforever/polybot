# -------------------------------------------------------
# POLYBOT — File di configurazione segreto
# Copia questo file in .env e compila i valori
# NON committare .env su Git!
# -------------------------------------------------------

# --- Credenziali API Polymarket ---
# Ottieni da: polymarket.com → Profilo → API Keys (serve VPN Ireland)
POLY_API_KEY=
POLY_SECRET=
POLY_PASSPHRASE=

# --- Hot Wallet ---
# Chiave privata del wallet MetaMask (non Ledger!)
# Deve avere USDC su rete Polygon e un po' di POL per gas
HOT_WALLET_PRIVATE_KEY=0x...

# --- Strategia ---
# Soglia di movimento % su Binance per generare segnale (es: 0.05 = 0.05%)
PRICE_THRESHOLD=0.05

# Finestra temporale in secondi per calcolare il movimento
WINDOW_SECONDS=10

# Prezzo massimo accettabile sul mercato Polymarket per comprare (es: 0.55 = 55 cents)
BUY_MAX_PRICE=0.55

# Dimensione ordine in USDC
BET_SIZE=2

# DRY_RUN: True = simulate only, False = ordini reali
DRY_RUN=True

# Intervallo loop principale in secondi
LOOP_INTERVAL=5

# --- Credenziali Web Dashboard ---
AUTH_USERNAME=admin
AUTH_PASSWORD=your_password_here
